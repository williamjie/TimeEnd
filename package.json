{
  "name": "timeend",
  "version": "1.0.0",
  "description": "强制中断计时器 - 专注工作，强制休息",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/bump-version.js && electron-builder",
    "build:no-bump": "electron-builder",
    "dev": "electron . --dev"
  },
  "keywords": [
    "timer",
    "pomodoro",
    "focus",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.timeend.app",
    "productName": "TimeEnd",
    "win": {
      "target": "nsis",
      "signingHashAlgorithms": [],
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
